<!-- src/views/pages/index.ejs -->
<div style="max-width: 1100px; margin: 0 auto; padding: 20px; font-family: system-ui, sans-serif;">

    <!-- Cabeçalho -->
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
        <h1 style="font-size: 28px; margin: 0;">📱 Shortz-App</h1>

        <div>
            <a href="/register" 
               style="margin-right: 12px; padding: 10px 20px; background: #000; color: white; text-decoration: none; border-radius: 8px;">
               Criar Conta
            </a>
            <a href="/login" 
               style="padding: 10px 20px; background: #eee; color: #000; text-decoration: none; border-radius: 8px;">
               Entrar
            </a>
        </div>
    </header>

    <!-- Hero -->
    <div style="text-align: center; margin-bottom: 60px;">
        <h2 style="font-size: 42px; margin-bottom: 16px;">Bem-vindo ao Shortz-App!</h2>
        <p style="font-size: 22px; color: #555; max-width: 600px; margin: 0 auto;">
            Vídeos curtos para aprender e inspirar.
        </p>
    </div>

    <!-- Vídeos em Destaque -->
    <h3 style="margin-bottom: 20px;">Vídeos em Destaque (Globais)</h3>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">

        <!-- Card 1 -->
        <div style="border: 1px solid #ddd; border-radius: 12px; overflow: hidden;">
            <div style="height: 180px; background: #333; display: flex; align-items: center; justify-content: center; color: white; font-size: 14px;">
                [Thumbnail Vídeo 1]
            </div>
            <div style="padding: 12px;">
                <p><strong>Título do vídeo 1</strong></p>
                <p style="color: #666; font-size: 14px;">@usuario1</p>
            </div>
        </div>

        <!-- Card 2 -->
        <div style="border: 1px solid #ddd; border-radius: 12px; overflow: hidden;">
            <div style="height: 180px; background: #333; display: flex; align-items: center; justify-content: center; color: white; font-size: 14px;">
                [Thumbnail Vídeo 2]
            </div>
            <div style="padding: 12px;">
                <p><strong>Título do vídeo 2</strong></p>
                <p style="color: #666; font-size: 14px;">@usuario2</p>
            </div>
        </div>

        <!-- Card 3 -->
        <div style="border: 1px solid #ddd; border-radius: 12px; overflow: hidden;">
            <div style="height: 180px; background: #333; display: flex; align-items: center; justify-content: center; color: white; font-size: 14px;">
                [Thumbnail Vídeo 3]
            </div>
            <div style="padding: 12px;">
                <p><strong>Título do vídeo 3</strong></p>
                <p style="color: #666; font-size: 14px;">@usuario3</p>
            </div>
        </div>
    </div>

    <div style="text-align: center; margin-top: 40px;">
        <a href="/login" 
           style="display: inline-block; padding: 14px 32px; background: #000; color: white; text-decoration: none; border-radius: 9999px; font-size: 18px;">
            Ver feed completo (requer login)
        </a>
    </div>

</div>